# Copy this file to `.env.local` and fill in what you have.

# Unpaywall needs a REAL, contactable email for its polite pool.
# Without it, the "Find free PDF" button is disabled (everything else works).
UNPAYWALL_EMAIL=your-real-email@gmail.com

# Optional — Semantic Scholar API key. Without it, S2 still works but is
# rate-limited (it may occasionally return errors; the app falls back to the
# other sources automatically).
# Get one at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
